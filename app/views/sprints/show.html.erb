<div class="flex-between" style="align-items: flex-start;">
  <div>
    <h1><%= @sprint.name %></h1>
    <p style="color: var(--text-secondary);">
      <strong>Início:</strong> <%= @sprint.start_date.strftime("%d/%m/%Y") %> &bull;
      <strong>Fim:</strong> <%= @sprint.end_date.strftime("%d/%m/%Y") %>
    </p>
  </div>
  <div style="display: flex; gap: 0.5rem;">
    <%= link_to 'Editar Sprint', edit_sprint_path(@sprint), class: "btn btn-secondary" %>
    <%= link_to 'Voltar', sprints_path, class: "btn btn-secondary" %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-top: 2rem;">
  
  <div>
    <h2 style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
      Tarefas da Sprint
      <span class="badge badge-em_revisao"><%= @tasks.count %> tarefas</span>
    </h2>

    <div class="task-list">
      <% @tasks.each do |task| %>
        <div class="task-item">
          <div class="task-header">
            <h3 class="task-title"><%= task.title %></h3>
            <div>
              <span class="badge badge-<%= task.status %>"><%= task.status.humanize %></span>
              <span class="badge" style="background-color: var(--bg-surface-hover); color: var(--text-secondary); margin-left: 0.5rem;"><%= task.story_points %> pts</span>
            </div>
          </div>
          
          <p class="task-desc"><%= task.description %></p>
          
          <div class="task-actions">
            <%= link_to 'Editar', edit_sprint_task_path(@sprint, task), class: "btn btn-secondary btn-small" %>
            <%= button_to 'Excluir', sprint_task_path(@sprint, task), method: :delete, data: { confirm: 'Tem certeza?' }, class: "btn btn-danger btn-small" %>
            
            <div style="margin-left: auto; display: flex; gap: 0.5rem;">
              <% Task::VALID_STATUSES.reject { |s| s == task.status }.each do |status| %>
                <%= button_to status.humanize, change_status_sprint_task_path(@sprint, task, status: status), method: :patch, class: "btn btn-secondary btn-small" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
      
      <% if @tasks.empty? %>
        <div style="text-align: center; padding: 3rem 1rem; border: 1px dashed var(--border-color); border-radius: var(--radius);">
          <p style="color: var(--text-secondary);">Nenhuma tarefa cadastrada nesta sprint ainda.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <div class="card" style="position: sticky; top: 2rem;">
      <h3 style="margin-bottom: 1.5rem;">Nova Tarefa</h3>
      
      <%= form_with(model: [@sprint, @task]) do |form| %>
        <% if @task.errors.any? %>
          <div class="alert">
            <h4 style="margin-bottom: 0.5rem; font-size: 0.875rem;"><%= pluralize(@task.errors.count, "erro") %> impediram de salvar:</h4>
            <ul style="margin-left: 1rem; font-size: 0.875rem;">
              <% @task.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= form.label :title, "Título", class: "form-label" %>
          <%= form.text_field :title, class: "form-control" %>
        </div>

        <div class="form-group">
          <%= form.label :description, "Descrição", class: "form-label" %>
          <%= form.text_area :description, class: "form-control", rows: 3 %>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <%= form.label :status, "Status", class: "form-label" %>
            <%= form.select :status, Task::VALID_STATUSES.map { |s| [s.humanize, s] }, {}, class: "form-control" %>
          </div>

          <div class="form-group">
            <%= form.label :story_points, "Story Points", class: "form-label" %>
            <%= form.number_field :story_points, class: "form-control" %>
          </div>
        </div>

        <div style="margin-top: 1rem;">
          <%= form.submit "Criar Tarefa", class: "btn btn-primary", style: "width: 100%;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
